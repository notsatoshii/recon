# RECON Configuration
# Copy to ~/.recon.env and fill in your values
# chmod 600 ~/.recon.env

# ── Telegram (create bot via @BotFather) ─────────────────────
export RECON_TELEGRAM_TOKEN=
export RECON_TELEGRAM_CHAT_ID=

# ── Reddit API ───────────────────────────────────────────────
# Create app at https://reddit.com/prefs/apps (type: script)
export REDDIT_CLIENT_ID=
export REDDIT_CLIENT_SECRET=
export REDDIT_USER_AGENT=RECON/1.0

# ── CryptoPanic (optional) ──────────────────────────────────
# Free key: https://cryptopanic.com/developers/api/
export CRYPTOPANIC_API_KEY=

# ── Dune Analytics (optional, future use) ────────────────────
# Free key: https://dune.com/settings/api
export DUNE_API_KEY=
