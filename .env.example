# RECON Environment Variables
# Copy this file to ~/.recon.env and fill in your values
# source ~/.recon.env before running scripts

# ─── REQUIRED ─────────────────────────────────────────────

# Telegram bot (create via @BotFather on Telegram)
export RECON_TELEGRAM_TOKEN=
export RECON_TELEGRAM_CHAT_ID=

# ─── OPTIONAL ─────────────────────────────────────────────

# Reddit API (not needed — RECON uses RSS feeds instead)
export REDDIT_CLIENT_ID=
export REDDIT_CLIENT_SECRET=
export REDDIT_USER_AGENT=RECON/1.0

# CryptoPanic (free key from cryptopanic.com/developers/api/)
export CRYPTOPANIC_API_KEY=

# Dune Analytics (free key from dune.com)
export DUNE_API_KEY=
